#include <iostream>
using namespace std;

void Print3xArray(int array[100][100], short Rows, short Cols) {
	for (int i = 0; i < Rows; i++) {
		for (int j = 0; j < Cols; j++)
			printf("%02d  ", array[i][j]);
		cout << "\n";
	}
}

bool CheckIfMatrisIsPalindrom(int Matrix[][100], short Rows, short Cols) {
	for (int i = 0; i < Rows; i++) {
		for (int j = 0; j < Cols / 2; j++) {
			if (Matrix[i][j] != Matrix[i][Cols - j - 1]) {
				return false;
			}
		}
	}
	return true;
}


int main() {

	int Matrix1[100][100]= { {1,2,1},{5,5,5},{7,3,7} };
	int Matrix2[100][100] = { {1,2,1},{5,5,5},{7,3,8} };
	short Rows = 3, Cols = 3;
	Print3xArray(Matrix1, Rows, Cols);
	cout << "Is Matrix1 a palindromic matrix? " << (CheckIfMatrisIsPalindrom(Matrix1, Rows, Cols) ? "YES" : "NO") << "\n";
	Print3xArray(Matrix2, Rows, Cols);
	cout << "Is Matrix2 a palindromic matrix? " << (CheckIfMatrisIsPalindrom(Matrix2, Rows, Cols) ? "YES" : "NO") << "\n";
  return 0;
}
