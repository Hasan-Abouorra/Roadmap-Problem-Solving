#include <iostream>
using namespace std;

oid PrintFibonacciSeriesUsingRecursion(int Number, int Prev1, int Prev2 ) {
	
	if (Number==0){
		cout << "\n";
		return;
	}

	int FebNumber = Prev1 + Prev2;
	Prev2 = Prev1;
	Prev1 = FebNumber;
	cout << FebNumber << "  ";
	return PrintFibonacciSeriesUsingRecursion((Number-1), Prev1, Prev2 );
}

int main() {

 PrintFibonacciSeriesUsingRecursion(10, 0, 1); cout << "\n";
 return 0;
}
